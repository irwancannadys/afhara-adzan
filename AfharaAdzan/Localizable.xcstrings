            "state" : "new",
            "value" : "%1$@  %2$@"
          }
        }
      }
    },
    "%@ • %@" : {
      "localizations" : {
        "id" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ • %2$@"
          }
        }
      }
    },
